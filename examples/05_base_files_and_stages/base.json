{
  "$schema": "chopper/base/v1",
  "domain": "my_domain",
  "owner": "platform-team",
  "tool": "my_tool",
  "description": "Base with files and stages. Use when you need both file inclusion control and flow generation — common in tools that read input scripts and generate run artifacts.",
  "files": {
    "include": [
      "setup.tcl",
      "vars.tcl",
      "procs/core_procs.tcl"
    ]
  },
  "stages": [
    {
      "name": "setup",
      "load_from": "",
      "command": "-xt vw Imy_shell -B BLOCK -T setup",
      "exit_codes": [0],
      "steps": [
        "source setup.tcl",
        "source vars.tcl"
      ]
    },
    {
      "name": "run_main",
      "load_from": "setup",
      "command": "-xt vw Imy_shell -B BLOCK -T run_main",
      "exit_codes": [0, 3, 5],
      "dependencies": ["setup"],
      "steps": [
        "source procs/core_procs.tcl",
        "run_main_flow",
        "save_session"
      ]
    }
  ]
}
