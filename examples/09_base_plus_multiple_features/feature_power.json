{
  "$schema": "chopper/feature/v1",
  "name": "power_analysis",
  "domain": "my_domain",
  "description": "Power analysis feature: adds power reporting procs and a power_check stage. No dependency on other features.",
  "metadata": {
    "owner": "power-team",
    "tags": ["power", "signoff"]
  },
  "files": {
    "include": ["procs/power_procs.tcl"]
  },
  "flow_actions": [
    {
      "action": "add_stage_after",
      "name": "power_check",
      "reference": "main",
      "load_from": "main",
      "command": "-xt vw Imy_shell -B BLOCK -T power_check",
      "exit_codes": [0, 3],
      "dependencies": ["main"],
      "steps": [
        "source procs/power_procs.tcl",
        "run_power_analysis",
        "report_power_summary"
      ]
    }
  ]
}
