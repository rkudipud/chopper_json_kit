{
  "$schema": "chopper/base/v1",
  "domain": "my_domain",
  "owner": "platform-team",
  "description": "Base for a domain with a standard flow. This becomes the unchanged foundation; the dft feature layers on top.",
  "files": {
    "include": [
      "setup.tcl",
      "vars.tcl",
      "procs/core_procs.tcl"
    ]
  },
  "stages": [
    {
      "name": "setup",
      "load_from": "",
      "command": "-xt vw Imy_shell -B BLOCK -T setup",
      "exit_codes": [0],
      "steps": [
        "source setup.tcl",
        "source vars.tcl"
      ]
    },
    {
      "name": "main",
      "load_from": "setup",
      "command": "-xt vw Imy_shell -B BLOCK -T main",
      "exit_codes": [0, 3, 5],
      "dependencies": ["setup"],
      "steps": [
        "source procs/core_procs.tcl",
        "run_main_flow"
      ]
    }
  ]
}
